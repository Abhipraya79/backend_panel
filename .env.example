# Server Configuration
PORT=5000
NODE_ENV=development

# MQTT Configuration
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=admin
MQTT_PASSWORD=secret_password
MQTT_CLIENT_ID=solar_backend_dev

# Firebase Configuration
FIREBASE_PROJECT_ID=solar-panel-iot-xxxx
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@solar-panel-iot-xxxx.iam.gserviceaccount.com
# Use standard RSA private key format, replace \n with actual newlines or double quotes for \n
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC3...\n-----END PRIVATE KEY-----\n"

# Security Configuration
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Telemetry Simulator Configuration
ENABLE_SIMULATOR=false

